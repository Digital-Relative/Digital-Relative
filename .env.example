VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-key

# Cron job authentication secret (generate with: openssl rand -hex 32)
CRON_SECRET=your-cron-secret-here

# Email sending (sign up at resend.com)
RESEND_API_KEY=re_your_resend_key_here

# Identity verification (sign up at onfido.com)
ONFIDO_API_KEY=your_onfido_api_key_here
ONFIDO_WEBHOOK_TOKEN=your_onfido_webhook_token_here

# Admin access for manual death certificate review
# Generate with: openssl rand -hex 32
ADMIN_SECRET_TOKEN=your-admin-secret-here


# Twilio SMS (optional - for SMS check-in reminders)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+44... (your Twilio phone number)

# Web Push (VAPID) - generated with web-push npm package
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here
# Add VAPID_PRIVATE_KEY and VAPID_PUBLIC_KEY to Supabase secrets too

# Crisp live chat (optional - free tier at crisp.chat)
# Add your Website ID from Crisp dashboard
VITE_CRISP_WEBSITE_ID=your_crisp_website_id_here

VITE_ADDRESSNOW_KEY=your_addressnow_key_here
